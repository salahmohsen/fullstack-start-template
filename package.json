  "type": "module",
  "scripts": {
    "dev": "vp dev",
    "preview": "vp preview",
    "start": "node .output/server/index.mjs",
    "test": "vp run --passWithNoTests",
    "test:resend:live": "vpx tsx  --env-file=.env ./scripts/test-resend-live.ts",
    "email:dev": "email dev --dir src/components/emails --port 5555",
    "db:generate": "drizzle-kit generate --config drizzle.config.ts",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:neon-setup": "vpx neondb",
    "db:setup-vector": "vpx tsx  --env-file=.env ./scripts/setup-vector-extension.ts",
    "auth:generate": "vpx @better-auth/cli generate --config ./src/lib/auth/auth.ts --output ./src/lib/db/schema/auth.ts",
    "add-ui-components": "vpx shadcn@latest add ",
    "format": "vp fmt",
    "format:check": "vp fmt --check",
    "check": "vp check",
    "check:fix": "vp check --fix",
    "docker:build": "docker build -t fullstack-app .",
    "docker:build:dev": "docker build -f Dockerfile.dev -t fullstack-app:dev .",
    "docker:run": "docker run -p 3000:3000 --env-file .env fullstack-app",
    "docker:run:dev": "docker run -p 3000:3000 --env-file .env fullstack-app:dev",
    "docker:clean": "docker system prune -f && docker image prune -f",
    "compose:up": "docker compose up --build",
    "compose:up:detached": "docker compose up --build -d",
    "compose:down": "docker compose down",
    "compose:logs": "docker compose logs -f",
    "compose:clean": "docker compose down -v --remove-orphans && docker system prune -f",
    "auth:secret": "vpx auth@latest secret",
    "tanstack": "vpx @tanstack/cli@latest",
    "skills": "vpx skills@latest",
    "intent": "vpx @tanstack/intent@latest"
  },
